---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;

// 1. 变量定义必须留在 --- 内部
// 如果没有写描述，截取 title 作为备选
const desc = frontmatter.description || `${frontmatter.title} - 最新技术博客文章`;
---

<BaseLayout title={frontmatter.title} description={desc}>
  <div class="max-w-3xl mx-auto mt-10">
    <!-- 修改这里的返回链接 -->
    <a href="/blog" class="text-blue-600 hover:underline mb-8 inline-block">⬅ 返回博客列表</a>
    
    <header class="mb-10 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 tracking-tight">
        {frontmatter.title}
      </h1>
      <div class="text-gray-500 font-medium flex items-center justify-center gap-2">
        <time datetime={frontmatter.date}>发布日期: {frontmatter.date}</time>
      </div>
    </header>

    <article class="prose prose-lg prose-blue mx-auto max-w-none">
      <slot />
    </article>

    <div class="mt-20 border-t border-gray-100 pt-10 text-center text-gray-400 text-sm">
      感谢阅读。如有疑问，欢迎通过 WhatsApp 联系我。
    </div>
  </div>
</BaseLayout>
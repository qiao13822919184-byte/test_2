---
// src/pages/products/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';

const title = "产品目录";
const description = "浏览我们的全线产品列表。";
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto">
    <div class="mb-8 border-b border-gray-100 pb-6">
      <h1 class="text-3xl font-bold text-gray-900">产品目录</h1>
      <p class="text-gray-500 mt-2">精选优质硬件，助力你的数字生活。</p>
    </div>

    <div class="flex flex-col gap-4">
      {products.map((product) => (
        <a 
          href={`/products/${product.id}`} 
          class="group flex items-center bg-white border border-gray-100 rounded-xl overflow-hidden shadow-sm hover:shadow-md hover:border-blue-200 transition-all duration-300"
        >
          {product.images && product.images.length > 0 && (
            <div class="w-32 h-32 sm:w-40 sm:h-40 flex-shrink-0 overflow-hidden bg-gray-50">
              <img 
                src={product.images[0]} 
                alt={product.name} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
              />
            </div>
          )}
          
          <div class="flex flex-col justify-between flex-grow p-4 sm:p-6 overflow-hidden">
            <div>
              <div class="flex justify-between items-start mb-1">
                <h3 class="text-lg sm:text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors truncate">
                  {product.name}
                </h3>
                <span class="text-blue-600 font-bold text-lg ml-4">${product.price}</span>
              </div>
              
              <p class="text-gray-500 text-sm line-clamp-2 leading-relaxed mb-2">
                {product.desc}
              </p>
            </div>

            <div class="flex items-center gap-3">
              <span class="text-[10px] px-2 py-0.5 bg-gray-100 text-gray-500 rounded uppercase tracking-wider font-semibold">
                库存充足
              </span>
              <span class="text-sm text-blue-500 font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                详情 <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>